# ─────────────────────────────────────────────────────────────────────────────
# KOMMUNITY — Configurazione .env per PRODUZIONE su cPanel
# Copia questo file come .env e compila tutti i valori mancanti.
# NON committare mai il .env reale su git.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=Kommunity
APP_ENV=production           # ← DEVE essere "production"
APP_KEY=base64:...           # ← Genera con: php artisan key:generate
APP_DEBUG=false              # ← DEVE essere false in produzione
APP_URL=https://tuodominio.it # ← URL completo con https://

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nome_database    # ← Nome DB su cPanel
DB_USERNAME=utente_db        # ← Utente DB su cPanel
DB_PASSWORD=password_sicura  # ← Password DB

# ── Cache & Sessioni ──────────────────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true   # ← true perché il sito usa HTTPS

# ── Log ───────────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_LEVEL=warning            # ← NON "debug" in produzione
LOG_DAILY_DAYS=30

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.tuodominio.it  # ← Server SMTP cPanel (o servizio esterno)
MAIL_PORT=587
MAIL_USERNAME=noreply@tuodominio.it
MAIL_PASSWORD=password_mail
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@tuodominio.it
MAIL_FROM_NAME="${APP_NAME}"

# ── Filesystem ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
