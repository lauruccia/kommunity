# Questo file va in public_html/media/.htaccess
# Instrada le richieste a file non esistenti verso Laravel (MediaController)
# così le immagini old (path members/avatars/...) vengono servite dal fallback PHP.

# ── SICUREZZA: blocca esecuzione script nella cartella upload ────────────────
# media/ contiene solo file caricati dagli utenti (immagini/video).
# Nessuno script deve MAI essere eseguito qui: se una webshell .php venisse
# caricata o piazzata in questa cartella, verrebbe servita come testo inerte.
<FilesMatch "\.(php|php[0-9]|phtml|phar|pl|py|cgi|sh|asp|aspx)$">
    Order allow,deny
    Deny from all
</FilesMatch>
RemoveHandler .php .phtml .phar
RemoveType .php .phtml .phar
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /media/

    # Se il file fisico esiste (nuovi upload in public_html/media/) → servilo direttamente
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Altrimenti (file vecchio in storage/) → passa a Laravel
    RewriteRule ^ /index.php [L]
</IfModule>
